# Database
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email login (optional — without it, use demo mode ?demo=1)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cashflowagent.dev

# Resend (for outbound email — https://resend.com/api-keys)
RESEND_API_KEY=
EMAIL_DOMAIN=cashflowagent.dev

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_CLIENT_ID=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Stripe webhook secret for /api/stripe/webhook
# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# App
APP_NAME="Cashflow Agent"