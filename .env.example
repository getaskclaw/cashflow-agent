# Database
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (for outbound email — https://resend.com/api-keys)
RESEND_API_KEY=
# Resend webhook secret for inbound email (/api/email/inbound)
RESEND_WEBHOOK_SECRET=
# Domain for reply-to addresses (reply+{invoiceId}@{domain})
EMAIL_DOMAIN=cashflowagent.dev
EMAIL_FROM=noreply@cashflowagent.dev

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_CLIENT_ID=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Stripe webhook secret for /api/stripe/webhook
# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# Python interpreter for agent scripts (default: python3)
CASHFLOW_PYTHON=python3

# Scripts directory (default: ./hermes-skill/scripts)
CASHFLOW_SCRIPTS_DIR=
# Override DB path for Python scripts (defaults to prisma/dev.db in repo)
# CASHFLOW_DB=

# Demo mode — disabled in production unless explicitly enabled
# ENABLE_DEMO_IN_PROD=true

# App
APP_NAME="Cashflow Agent"