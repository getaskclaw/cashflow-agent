# Database
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Email login (optional — without it, use magic link demo mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@cashflowagent.dev

# Stripe — get these from https://dashboard.stripe.com/apikeys
# Stripe Connect OAuth
STRIPE_CLIENT_ID=
# Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=
# Stripe webhook secret for /api/stripe/webhook
# Get from https://dashboard.stripe.com/webhooks (endpoint: yourdomain.com/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=

# App
APP_NAME="Cashflow Agent"
