generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  stripeConnection StripeConnection?
  transactions     Transaction[]
  taxCalculations  TaxCalculation[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StripeConnection {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeAccountId String   @unique
  accessToken     String
  refreshToken    String?
  stripePublishableKey String?
  stripeUserId    String?
  connectedAt     DateTime @default(now())
  livemode        Boolean  @default(true)
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeChargeId  String   @unique
  amount          Int      // cents
  currency        String   @default("usd")
  customerName    String?
  customerEmail   String?
  customerCountry String?
  customerState   String?
  customerZip     String?
  customerCity    String?
  description     String?
  metadata        String?  // JSON blob
  createdAt       DateTime
  syncedAt        DateTime @default(now())

  taxCalculation TaxCalculation?
}

model TaxCalculation {
  id              String   @id @default(cuid())
  transactionId   String   @unique
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Jurisdiction info
  jurisdictionType  String   // "us_state", "eu_country", "ca_province", "au", "other"
  jurisdictionName  String   // e.g. "California", "Germany"
  jurisdictionCode  String   // e.g. "US-CA", "DE"

  // Rate & amount
  taxRate     Float    // e.g. 0.0875 for 8.75%
  taxAmount   Int      // calculated tax in cents
  taxableAmount Int    // amount subject to tax in cents

  // Breakdown
  stateRate   Float?
  localRate   Float?
  countryRate Float?

  // Status
  status      String   @default("calculated") // calculated, filed, exempt
  notes       String?
  calculatedAt DateTime @default(now())
}
